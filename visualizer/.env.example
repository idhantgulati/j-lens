# J-Lens Visualizer — copy to visualizer/.env and fill in.
# The .env file is gitignored; values are pushed to Modal as the "supabase-jlens"
# secret (modal secret create supabase-jlens ... reads these).

# --- Supabase (request logging) -----------------------------------------
# Project URL: Supabase dashboard -> Project Settings -> API -> Project URL
SUPABASE_URL=
# Service role key (NOT the anon key): Project Settings -> API -> service_role
# Bypasses RLS; server-side only, never shipped to the browser.
SUPABASE_SERVICE_KEY=

# --- Optional ------------------------------------------------------------
# Only needed if you ever switch to a gated HF model; Qwen3.5-4B is public.
# HF_TOKEN=

# Modal auth is NOT configured here — the `modal` CLI is already authenticated
# on this machine (profile: order-evaluation). Vercel auth likewise goes through
# `vercel login` / the Vercel integration, not this file.
